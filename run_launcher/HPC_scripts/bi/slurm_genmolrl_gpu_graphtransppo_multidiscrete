#!/bin/bash
#!
#! SLURM job script for GenMolRL Bi-GraphTransPPO MultiDiscrete
#! (run_genmolrl_graphtransppo_bi_multidiscrete.sh, hand-rolled
#! GraphTransBiPPO trainer with π(T | R1) · π(R2 | R1) independent-axis
#! policy on a GraphTransformer encoder over R1). Pair:
#! run_launcher/HPC_scripts/bi/slurm_genmolrl_gpu_graphtransppo_hierarchical.
#!
#! Multidiscrete is the baseline / ablation against the hierarchical
#! variant; the R2 distribution is shared across templates, which makes
#! learning a useful R2 selector harder than under the hierarchical T-
#! conditional R2 head. Same GraphTransformer encoder, same compute
#! profile as the hierarchical SLURM script.
#!

#!#############################################################
#!#### Modify the options in this section as appropriate ######
#!#############################################################

#! sbatch directives begin here ###############################
#! Name of the job:
#SBATCH -J genmolrl_graphppo_bi_md
#! Which project should be charged (NB Wilkes2 projects end in '-GPU'):
#SBATCH -A OZTIRELI-SL2-GPU
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:1
#SBATCH --time=36:00:00
#SBATCH --mail-user=bz317@cam.ac.uk
#SBATCH --mail-type=ALL

#SBATCH -p ampere

##SBATCH -o logs/graphtransppo_bi_md_%j.out
##SBATCH -e logs/graphtransppo_bi_md_%j.err

#! sbatch directives end here #################################

#! Optional overrides: CONDA_ENV, REACTION_MODE, MASKING, REWARD, CONFIG, EXPERIMENT_NAME
#! Submit: cd /home/bz317/rds/hpc-work/GenMolRL/GenMolRL && sbatch run_launcher/HPC_scripts/bi/slurm_genmolrl_gpu_graphtransppo_multidiscrete

numnodes=$SLURM_JOB_NUM_NODES
numtasks=$SLURM_NTASKS
mpi_tasks_per_node=$(echo "$SLURM_TASKS_PER_NODE" | sed -e  's/^\([0-9][0-9]*\).*$/\1/')

. /etc/profile.d/modules.sh
module purge
module load rhel8/default-amp

CONDA_ROOT="${CONDA_ROOT:-/home/bz317/rds/hpc-work/miniconda3}"
source "${CONDA_ROOT}/etc/profile.d/conda.sh"
CONDA_ENV="${CONDA_ENV:-RL_for_new_mol}"
conda activate "${CONDA_ENV}"

#! Resolve the project root (the directory holding `genmolrl/`, `configs/`,
#! `data/`, `runs/`, `run_launcher/`, ...). Same fallback chain as the
#! hierarchical SLURM script so the two are submit-from-anywhere safe.
LAUNCHER_REL="run_launcher/HPC_sh_files/run_genmolrl_graphtransppo_bi_multidiscrete.sh"
for _cand in "${SLURM_SUBMIT_DIR}" "${SLURM_SUBMIT_DIR}/.." "${SLURM_SUBMIT_DIR}/../.." "${SLURM_SUBMIT_DIR}/../../.." "/home/bz317/rds/hpc-work/GenMolRL/GenMolRL"; do
  if [ -f "${_cand}/${LAUNCHER_REL}" ]; then
    PROJECT_ROOT="$(cd "${_cand}" && pwd)"
    break
  fi
done
unset _cand
LAUNCHER_PATH="${PROJECT_ROOT}/${LAUNCHER_REL}"

export OMP_NUM_THREADS=1
export PYTHONUNBUFFERED=1

cd "${PROJECT_ROOT}"
mkdir -p logs
JOBID=$SLURM_JOB_ID

# YAML owns experiment_name; SLURM only tags the run with _HPC.
export WANDB_RUN_POST_APPEND="${WANDB_RUN_POST_APPEND:-HPC}"

CMD="bash \"${LAUNCHER_PATH}\""
CMD="$CMD 2>&1 | tee logs/graphtransppo_bi_md_${JOBID}.log"

echo -e "JobID: $JOBID\n======"
echo "Time: $(date)"
echo "Running on: $(hostname)"
echo "PROJECT_ROOT: ${PROJECT_ROOT}"
echo "CONDA_ROOT: ${CONDA_ROOT}"
echo "CONDA_ENV: ${CONDA_ENV}"
echo "WANDB_RUN_POST_APPEND: ${WANDB_RUN_POST_APPEND}"
echo -e "\nnumtasks=$numtasks, numnodes=$numnodes (OMP_NUM_THREADS=$OMP_NUM_THREADS)"
echo -e "\nExecuting:\n==================\n$CMD\n"

eval $CMD
