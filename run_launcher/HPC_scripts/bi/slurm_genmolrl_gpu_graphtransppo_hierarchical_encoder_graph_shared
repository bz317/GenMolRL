#!/bin/bash
#!
#! SLURM job script for GenMolRL Bi-GraphTransPPO Hierarchical with
#! r2_arch: encoder_graph_shared (weight-tied R2 GraphTransformer).
#! Uses run_genmolrl_graphtransppo_bi_hierarchical_encoder_graph_shared.sh
#! and configs/graphtransppo_bi_hierarchical_encoder_graph_shared_delta_qed.yaml.
#!
#! NOT the lookup baseline — use slurm_genmolrl_gpu_graphtransppo_hierarchical
#! for r2_arch: lookup. This job can OOM on the first PPO update if the
#! full train R2 pool forward does not fit in GPU memory.
#!

#! sbatch directives begin here ###############################
#SBATCH -J genmolrl_gtbi_hier_egs
#SBATCH -A OZTIRELI-SL2-GPU
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:1
#SBATCH --time=36:00:00
#SBATCH --mail-user=bz317@cam.ac.uk
#SBATCH --mail-type=ALL
#SBATCH -p ampere
##SBATCH -o logs/graphtransppo_bi_hier_egs_%j.out
##SBATCH -e logs/graphtransppo_bi_hier_egs_%j.err
#! sbatch directives end here #################################

#! Submit: cd /path/to/GenMolRL && sbatch run_launcher/HPC_scripts/bi/slurm_genmolrl_gpu_graphtransppo_hierarchical_encoder_graph_shared

numnodes=$SLURM_JOB_NUM_NODES
numtasks=$SLURM_NTASKS
mpi_tasks_per_node=$(echo "$SLURM_TASKS_PER_NODE" | sed -e  's/^\([0-9][0-9]*\).*$/\1/')

. /etc/profile.d/modules.sh
module purge
module load rhel8/default-amp

CONDA_ROOT="${CONDA_ROOT:-/home/bz317/rds/hpc-work/miniconda3}"
source "${CONDA_ROOT}/etc/profile.d/conda.sh"
CONDA_ENV="${CONDA_ENV:-RL_for_new_mol}"
conda activate "${CONDA_ENV}"

LAUNCHER_REL="run_launcher/HPC_sh_files/run_genmolrl_graphtransppo_bi_hierarchical_encoder_graph_shared.sh"
for _cand in "${SLURM_SUBMIT_DIR}" "${SLURM_SUBMIT_DIR}/.." "${SLURM_SUBMIT_DIR}/../.." "${SLURM_SUBMIT_DIR}/../../.." "/home/bz317/rds/hpc-work/GenMolRL/GenMolRL"; do
  if [ -f "${_cand}/${LAUNCHER_REL}" ]; then
    PROJECT_ROOT="$(cd "${_cand}" && pwd)"
    break
  fi
done
unset _cand
LAUNCHER_PATH="${PROJECT_ROOT}/${LAUNCHER_REL}"

export OMP_NUM_THREADS=1
export PYTHONUNBUFFERED=1

cd "${PROJECT_ROOT}"
mkdir -p logs
JOBID=$SLURM_JOB_ID

export WANDB_RUN_POST_APPEND="${WANDB_RUN_POST_APPEND:-HPC}"

CMD="bash \"${LAUNCHER_PATH}\""
CMD="$CMD 2>&1 | tee logs/graphtransppo_bi_hier_egs_${JOBID}.log"

echo -e "JobID: $JOBID\n======"
echo "Time: $(date)"
echo "Running on: $(hostname)"
echo "PROJECT_ROOT: ${PROJECT_ROOT}"
echo "CONDA_ENV: ${CONDA_ENV}"
echo -e "\nExecuting:\n==================\n$CMD\n"

eval $CMD
